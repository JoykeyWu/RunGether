<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_panel"
    android:orientation="vertical"
    android:padding="@dimen/space_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_brand_soft"
            android:contentDescription="@null"
            android:padding="12dp"
            android:src="@drawable/ic_user" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_contact_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/guide_navy"
                android:textSize="@dimen/text_guide_body_lg"
                android:textStyle="bold"
                tools:text="张伟" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_phone" />

                <TextView
                    android:id="@+id/tv_contact_phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/guide_navy_70"
                    android:textSize="@dimen/text_guide_body"
                    tools:text="138 0013 8000" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/space_md"
        android:background="@color/guide_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_contact_edit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_brand_outline"
            android:clickable="true"
            android:drawableStart="@drawable/ic_pen"
            android:drawablePadding="4dp"
            android:focusable="true"
            android:gravity="center"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingVertical="@dimen/space_sm"
            android:text="@string/action_edit"
            android:textColor="@color/guide_brand"
            android:textSize="@dimen/text_guide_body"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_contact_delete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_danger_outline"
            android:clickable="true"
            android:drawableStart="@drawable/ic_trash"
            android:drawablePadding="4dp"
            android:focusable="true"
            android:gravity="center"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingVertical="@dimen/space_sm"
            android:text="@string/action_delete"
            android:textColor="@color/guide_danger"
            android:textSize="@dimen/text_guide_body"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
