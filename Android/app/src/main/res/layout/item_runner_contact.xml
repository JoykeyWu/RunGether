<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_runner_card"
    android:orientation="vertical"
    android:padding="@dimen/space_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_runner_border_accent">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_user"
                android:tint="@color/runner_accent" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_contact_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/runner_high"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="张伟" />

            <TextView
                android:id="@+id/tv_contact_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="138 0013 8000" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/space_md"
        android:background="@color/runner_overlay_white_30" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_contact_edit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_runner_outline_accent"
            android:clickable="true"
            android:drawableStart="@drawable/ic_pen"
            android:drawablePadding="6dp"
            android:drawableTint="@color/runner_accent"
            android:focusable="true"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="@string/action_edit"
            android:textColor="@color/runner_accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_contact_delete"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_runner_outline_danger"
            android:clickable="true"
            android:drawableStart="@drawable/ic_trash"
            android:drawablePadding="6dp"
            android:drawableTint="@color/runner_danger"
            android:focusable="true"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:text="@string/action_delete"
            android:textColor="@color/runner_danger"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
