<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runner_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_md">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:contentDescription="@string/action_back"
                android:focusable="true"
                android:padding="10dp"
                android:src="@drawable/ic_chevron_left"
                android:tint="@color/runner_high" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/runner_history_title"
                android:textColor="@color/runner_high"
                android:textSize="22sp"
                android:textStyle="bold" />

            <View
                android:layout_width="44dp"
                android:layout_height="44dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/runner_border" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_runner_panel_warn"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_md"
            android:paddingVertical="10dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_volume_high"
                android:tint="@color/runner_accent" />

            <TextView
                android:id="@+id/tv_speech_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:textColor="@color/runner_accent"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="语音浏览中：共 4 条记录" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_history"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_md"
            android:paddingBottom="@dimen/space_md"
            tools:listitem="@layout/item_runner_history" />

        <TextView
            android:id="@+id/tv_long_press_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="@dimen/space_sm"
            android:text="@string/runner_history_long_press_hint"
            android:textColor="@color/runner_overlay_white_65"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_circle_runner_border_accent"
                android:contentDescription="@null"
                android:padding="20dp"
                android:src="@drawable/ic_clock_history"
                android:tint="@color/runner_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/runner_history_empty_title"
                android:textColor="@color/runner_high"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center"
                android:text="@string/runner_history_empty_subtitle"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/delete_dialog_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="@dimen/space_2xl"
            android:background="@drawable/bg_runner_dialog"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_circle_runner_border_white"
                android:contentDescription="@null"
                android:padding="14dp"
                android:src="@drawable/ic_trash"
                android:tint="@color/runner_danger" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:text="@string/dialog_delete_confirm_title"
                android:textColor="@color/runner_high"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_delete_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="16sp"
                tools:text="确认删除 2026-05-20\n的跑步记录？" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_delete_cancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_runner_outline_white"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingVertical="@dimen/space_md"
                    android:text="@string/action_cancel"
                    android:textColor="@color/runner_high"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_delete_confirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_runner_btn_danger"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingVertical="@dimen/space_md"
                    android:text="@string/action_delete"
                    android:textColor="@color/runner_high"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
