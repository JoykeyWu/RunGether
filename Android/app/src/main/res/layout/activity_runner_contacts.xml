<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runner_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_md">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_runner_back_icon"
                android:clickable="true"
                android:contentDescription="@string/action_back"
                android:focusable="true"
                android:padding="10dp"
                android:src="@drawable/ic_chevron_left"
                android:tint="@color/runner_high" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/runner_contacts_title"
                android:textColor="@color/runner_high"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_add_contact"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_runner_add_btn"
                android:clickable="true"
                android:contentDescription="@string/runner_contacts_form_add_title"
                android:focusable="true"
                android:padding="10dp"
                android:src="@drawable/ic_plus"
                android:tint="@color/runner_bg" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/runner_border" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_contacts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_md"
            android:paddingBottom="80dp"
            tools:listitem="@layout/item_runner_contact" />

        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_circle_runner_border_accent"
                android:contentDescription="@null"
                android:padding="20dp"
                android:src="@drawable/ic_user"
                android:tint="@color/runner_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/runner_contacts_empty_title"
                android:textColor="@color/runner_high"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center"
                android:text="@string/runner_contacts_empty_subtitle"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="@dimen/space_2xl"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_shield_halved"
            android:tint="@color/runner_accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/runner_contacts_footer"
            android:textColor="@color/runner_overlay_white_65"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/form_sheet_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_runner_dialog_accent"
            android:orientation="vertical"
            android:padding="@dimen/space_2xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_form_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/runner_contacts_form_add_title"
                    android:textColor="@color/runner_high"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btn_form_close"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:clickable="true"
                    android:contentDescription="@string/action_close"
                    android:focusable="true"
                    android:padding="4dp"
                    android:src="@drawable/ic_xmark"
                    android:tint="@color/runner_high" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/runner_contacts_form_name_label"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_contact_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_runner_input"
                android:hint="@string/runner_contacts_form_name_hint"
                android:inputType="text"
                android:maxLength="20"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingVertical="14dp"
                android:textColor="@color/runner_high"
                android:textColorHint="@color/runner_overlay_white_40"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="@string/runner_contacts_form_phone_label"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_contact_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_runner_input"
                android:hint="@string/runner_contacts_form_phone_hint"
                android:inputType="phone"
                android:maxLength="13"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingVertical="14dp"
                android:textColor="@color/runner_high"
                android:textColorHint="@color/runner_overlay_white_40"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_form_cancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_runner_outline_white"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingVertical="@dimen/space_md"
                    android:text="@string/action_cancel"
                    android:textColor="@color/runner_high"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_form_save"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_runner_btn_accent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingVertical="@dimen/space_md"
                    android:text="@string/action_save"
                    android:textColor="@color/runner_bg"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/delete_dialog_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="@dimen/space_2xl"
            android:background="@drawable/bg_runner_dialog_danger"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_circle_runner_border_white"
                android:contentDescription="@null"
                android:padding="14dp"
                android:src="@drawable/ic_trash"
                android:tint="@color/runner_danger" />

            <TextView
                android:id="@+id/tv_delete_dialog_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:textColor="@color/runner_high"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="确认删除联系人 张伟？" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="@string/runner_contacts_delete_subtitle"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xl"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_delete_cancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_runner_outline_white"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingVertical="@dimen/space_md"
                    android:text="@string/action_cancel"
                    android:textColor="@color/runner_high"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_delete_confirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_runner_btn_danger"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingVertical="@dimen/space_md"
                    android:text="@string/action_delete"
                    android:textColor="@color/runner_high"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
