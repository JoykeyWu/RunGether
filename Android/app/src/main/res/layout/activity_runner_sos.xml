<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runner_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_sm"
        android:background="@drawable/bg_runner_sos_title"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/space_lg">

        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp">

            <View
                android:id="@+id/pulse_ring"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_runner_pulse_white" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_circle_runner_solid_white">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_warning_triangle"
                    android:tint="@color/runner_danger" />
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:letterSpacing="0.1"
            android:text="@string/runner_sos_title"
            android:textColor="@color/runner_high"
            android:textSize="@dimen/text_runner_title"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_volume_high"
                android:tint="@color/runner_high" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:text="@string/runner_sos_speech"
                android:textColor="@color/runner_high"
                android:textSize="@dimen/text_guide_body_lg"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_md"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_runner_panel_accent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_md">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_warning_triangle"
                android:tint="@color/runner_accent" />

            <TextView
                android:id="@+id/tv_status_torch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_weight="1"
                android:text="@string/runner_sos_status_torch"
                android:textColor="@color/runner_high"
                android:textSize="@dimen/text_guide_body_lg"
                android:textStyle="bold" />

            <View
                android:id="@+id/dot_status_torch"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_runner_dot_warn" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/bg_runner_panel_accent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_md">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_volume_high"
                android:tint="@color/runner_accent" />

            <TextView
                android:id="@+id/tv_status_alarm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_weight="1"
                android:text="@string/runner_sos_status_alarm"
                android:textColor="@color/runner_high"
                android:textSize="@dimen/text_guide_body_lg"
                android:textStyle="bold" />

            <View
                android:id="@+id/dot_status_alarm"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_runner_dot_warn" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/bg_runner_panel_check"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_md">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_check"
                android:tint="@color/runner_success" />

            <TextView
                android:id="@+id/tv_status_notify"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_weight="1"
                android:text="@string/runner_sos_status_notify"
                android:textColor="@color/runner_high"
                android:textSize="@dimen/text_guide_body_lg"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="@dimen/space_lg"
        android:layout_marginTop="@dimen/space_md"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_phone_volume"
                android:tint="@color/runner_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:text="@string/runner_sos_contacts_label"
                android:textColor="@color/runner_high"
                android:textSize="@dimen/text_guide_body_lg"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_contacts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/space_sm"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="@dimen/space_sm" />

        <TextView
            android:id="@+id/tv_contacts_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="@dimen/space_lg"
            android:text="@string/runner_sos_no_contacts"
            android:textColor="@color/runner_high_70"
            android:textSize="@dimen/text_guide_body_lg"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_dismiss"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/space_lg"
        android:layout_marginBottom="@dimen/space_xl"
        android:background="@drawable/bg_runner_btn_bottom"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:letterSpacing="0.1"
        android:paddingVertical="@dimen/space_xl"
        android:text="@string/runner_sos_dismiss"
        android:textColor="@color/runner_high"
        android:textSize="@dimen/text_runner_body_lg"
        android:textStyle="bold" />
</LinearLayout>
