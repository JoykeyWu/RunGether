<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runner_bg"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/chip_connection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/bg_runner_panel_success"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingVertical="@dimen/space_md">

            <View
                android:id="@+id/dot_connection"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_runner_dot_success" />

            <TextView
                android:id="@+id/tv_connection"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_weight="1"
                android:text="@string/runner_status_connected"
                android:textColor="@color/runner_success"
                android:textSize="@dimen/text_guide_body_lg"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_volume_high"
                android:tint="@color/runner_success" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/state_idle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@drawable/bg_runner_panel"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:paddingVertical="@dimen/space_xl">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_shoe_prints"
                        android:tint="@color/runner_high" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/runner_idle_title"
                        android:textColor="@color/runner_high"
                        android:textSize="@dimen/text_runner_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/runner_idle_subtitle"
                        android:textColor="@color/runner_high_70"
                        android:textSize="@dimen/text_runner_body" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_start_run"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_xl"
                    android:background="@drawable/bg_runner_btn_success"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:paddingVertical="@dimen/space_2xl">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_play"
                        android:tint="@color/runner_bg" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:letterSpacing="0.1"
                        android:text="@string/runner_btn_start_title"
                        android:textColor="@color/runner_bg"
                        android:textSize="@dimen/text_runner_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/runner_btn_start_subtitle"
                        android:textColor="@color/runner_bg"
                        android:textSize="@dimen/text_guide_body"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_sos_idle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@drawable/bg_runner_btn_danger"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:paddingVertical="@dimen/space_2xl">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_warning_triangle"
                        android:tint="@color/runner_high" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:letterSpacing="0.1"
                        android:text="@string/runner_btn_sos_title"
                        android:textColor="@color/runner_high"
                        android:textSize="@dimen/text_runner_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/runner_btn_sos_subtitle"
                        android:textColor="@color/runner_high"
                        android:textSize="@dimen/text_guide_body"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/state_running"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@drawable/bg_runner_panel"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:paddingVertical="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_clock_history"
                            android:tint="@color/runner_high_70" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_sm"
                            android:text="@string/runner_running_label"
                            android:textColor="@color/runner_high_70"
                            android:textSize="@dimen/text_guide_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_duration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_duration_zero"
                                android:textColor="@color/runner_high"
                                android:textSize="@dimen/text_runner_h1"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_xs"
                                android:text="@string/runner_metric_duration"
                                android:textColor="@color/runner_high_70"
                                android:textSize="@dimen/text_guide_body" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_distance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder_distance_zero"
                                android:textColor="@color/runner_accent"
                                android:textSize="@dimen/text_runner_h1"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/space_xs"
                                android:text="@string/runner_metric_distance"
                                android:textColor="@color/runner_high_70"
                                android:textSize="@dimen/text_guide_body" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_end_run"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_xl"
                    android:background="@drawable/bg_runner_btn_accent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:paddingVertical="@dimen/space_2xl">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_stop"
                        android:tint="@color/runner_bg" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:letterSpacing="0.1"
                        android:text="@string/runner_btn_end_title"
                        android:textColor="@color/runner_bg"
                        android:textSize="@dimen/text_runner_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/runner_btn_end_subtitle"
                        android:textColor="@color/runner_bg"
                        android:textSize="@dimen/text_guide_body"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_sos_running"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_lg"
                    android:background="@drawable/bg_runner_btn_danger"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/space_lg"
                    android:paddingVertical="@dimen/space_2xl">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_warning_triangle"
                        android:tint="@color/runner_high" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:letterSpacing="0.1"
                        android:text="@string/runner_btn_sos_title"
                        android:textColor="@color/runner_high"
                        android:textSize="@dimen/text_runner_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_xs"
                        android:text="@string/runner_btn_sos_subtitle"
                        android:textColor="@color/runner_high"
                        android:textSize="@dimen/text_guide_body"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_xl"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btn_history"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_runner_btn_bottom"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_md">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_clock_history"
                    android:tint="@color/runner_high" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/runner_bottom_history"
                    android:textColor="@color/runner_high"
                    android:textSize="@dimen/text_guide_body_lg"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_settings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_weight="1"
                android:background="@drawable/bg_runner_btn_bottom"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="@dimen/space_md">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_gear"
                    android:tint="@color/runner_high" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/runner_bottom_settings"
                    android:textColor="@color/runner_high"
                    android:textSize="@dimen/text_guide_body_lg"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
