<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runner_bg"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingVertical="@dimen/space_md">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@string/action_back"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_chevron_left"
            android:tint="@color/runner_high" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/runner_about_title"
            android:textColor="@color/runner_high"
            android:textSize="22sp"
            android:textStyle="bold" />

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/runner_border" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/space_3xl">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="@dimen/space_3xl">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_runner_about_logo"
                    android:contentDescription="@null"
                    android:padding="22dp"
                    android:src="@drawable/ic_shoe_prints"
                    android:tint="@color/runner_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_lg"
                    android:letterSpacing="0.1"
                    android:text="@string/app_brand"
                    android:textColor="@color/runner_high"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/runner_about_subtitle"
                    android:textColor="@color/runner_overlay_white_65"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_about_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_runner_about_version"
                    android:paddingHorizontal="@dimen/space_md"
                    android:paddingVertical="4dp"
                    android:textColor="@color/runner_accent"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="v1.0.0" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_2xl"
                android:background="@drawable/bg_runner_panel"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_book_open"
                        android:tint="@color/runner_accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:text="@string/runner_about_intro_title"
                        android:textColor="@color/runner_high"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:lineSpacingExtra="6dp"
                    android:text="@string/runner_about_intro_body"
                    android:textColor="@color/runner_overlay_white_65"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_md"
                android:background="@drawable/bg_runner_panel"
                android:orientation="vertical"
                android:padding="@dimen/space_lg">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_users"
                        android:tint="@color/runner_accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:text="@string/runner_about_team_title"
                        android:textColor="@color/runner_high"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_sm"
                    android:lineSpacingExtra="6dp"
                    android:text="@string/runner_about_team_body"
                    android:textColor="@color/runner_overlay_white_65"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2xl"
                android:gravity="center"
                android:text="@string/runner_about_copyright"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
