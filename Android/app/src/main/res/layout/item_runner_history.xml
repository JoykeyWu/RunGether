<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_runner_card"
    android:clickable="true"
    android:focusable="true"
    android:longClickable="true"
    android:orientation="vertical"
    android:padding="@dimen/space_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_calendar"
            android:tint="@color/runner_accent" />

        <TextView
            android:id="@+id/tv_item_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_sm"
            android:layout_weight="1"
            android:textColor="@color/runner_high"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="2026-05-20" />

        <TextView
            android:id="@+id/tv_item_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_runner_chip_accent"
            android:paddingHorizontal="@dimen/space_sm"
            android:paddingVertical="2dp"
            android:textColor="@color/runner_bg"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="今天"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tv_item_relative"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/runner_overlay_white_65"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="2 天前" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_md"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_item_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/runner_accent"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="4.15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/item_history_distance"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_item_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/runner_high"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="32:18" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/item_history_duration"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_item_pace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/runner_high"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="7'47''" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/item_history_pace"
                android:textColor="@color/runner_overlay_white_65"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
