<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/guide_bg_light"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/space_lg"
            android:paddingTop="@dimen/space_sm"
            android:paddingBottom="@dimen/space_md">

            <LinearLayout
                android:id="@+id/chip_connection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_chip"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <View
                    android:id="@+id/dot_connection"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_success" />

                <TextView
                    android:id="@+id/tv_connection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/guide_status_disconnected"
                    android:textColor="@color/guide_success"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/btn_history"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_icon"
                android:clickable="true"
                android:contentDescription="@string/page_guide_history"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/ic_clock_history" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_circle_icon"
                android:clickable="true"
                android:contentDescription="@string/page_guide_settings"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/ic_gear" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/state_idle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_2xl"
                    android:background="@drawable/bg_card_panel"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="@dimen/space_2xl">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_circle_brand_soft"
                        android:contentDescription="@null"
                        android:padding="20dp"
                        android:src="@drawable/ic_shoe_prints"
                        android:tint="@color/guide_brand" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:text="@string/guide_idle_title"
                        android:textColor="@color/guide_navy"
                        android:textSize="@dimen/text_guide_title"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_idle_subtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:gravity="center"
                        android:lineSpacingExtra="4dp"
                        android:text="@string/guide_idle_subtitle"
                        android:textColor="@color/guide_navy_45"
                        android:textSize="@dimen/text_guide_body" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btn_start_run"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_xl"
                    android:background="@drawable/bg_btn_brand"
                    android:clickable="true"
                    android:drawableStart="@drawable/ic_play"
                    android:drawablePadding="@dimen/space_sm"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="18dp"
                    android:text="@string/guide_btn_start"
                    android:textColor="@color/color_white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/btn_open_pair"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginBottom="@dimen/space_2xl"
                    android:background="@drawable/bg_btn_brand_outline"
                    android:clickable="true"
                    android:drawableStart="@drawable/ic_bluetooth"
                    android:drawablePadding="@dimen/space_sm"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="14dp"
                    android:text="@string/guide_bluetooth_manage"
                    android:textColor="@color/guide_brand"
                    android:textSize="@dimen/text_guide_body"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/state_running"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_sm"
                    android:background="@drawable/bg_card_panel"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_pace"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_pace_dashes"
                            android:textColor="@color/guide_navy"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/guide_metric_pace"
                            android:textColor="@color/guide_navy_45"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/guide_divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_distance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_distance_zero"
                            android:textColor="@color/guide_brand"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/guide_metric_distance"
                            android:textColor="@color/guide_navy_45"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/guide_divider" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_duration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/placeholder_duration_zero"
                            android:textColor="@color/guide_navy"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/guide_metric_duration"
                            android:textColor="@color/guide_navy_45"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_md"
                    android:background="@drawable/bg_card_panel">

                    <com.rungether.app.ui.widget.TrackView
                        android:id="@+id/track_view"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|top"
                        android:layout_margin="8dp"
                        android:background="@drawable/bg_card_white"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="3dp">

                        <ImageView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_location_dot" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/guide_track_follow"
                            android:textColor="@color/guide_navy_70"
                            android:textSize="10sp" />
                    </LinearLayout>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginTop="@dimen/space_md"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_panel"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="@dimen/space_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/guide_joystick_label"
                            android:textColor="@color/guide_navy_45"
                            android:textSize="10sp" />

                        <com.rungether.app.ui.widget.JoystickView
                            android:id="@+id/joystick"
                            android:layout_width="160dp"
                            android:layout_height="160dp"
                            android:layout_marginTop="@dimen/space_xs" />

                        <TextView
                            android:id="@+id/tv_direction_hint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:text="@string/guide_joystick_default"
                            android:textColor="@color/guide_navy_70"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_md"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/btn_shortcut_obstacle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_panel"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="12dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_warning_triangle" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/guide_shortcut_obstacle"
                                android:textColor="@color/guide_navy"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btn_shortcut_slow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:background="@drawable/bg_card_panel"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="12dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_gauge" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/guide_shortcut_slow"
                                android:textColor="@color/guide_navy"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btn_shortcut_stop"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_sm"
                            android:background="@drawable/bg_card_panel"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:paddingVertical="12dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:contentDescription="@null"
                                android:src="@drawable/ic_hand_stop" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/guide_shortcut_stop"
                                android:textColor="@color/guide_navy"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/btn_end_run"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/space_lg"
                    android:layout_marginBottom="@dimen/space_2xl"
                    android:background="@drawable/bg_btn_danger"
                    android:clickable="true"
                    android:drawableStart="@drawable/ic_stop"
                    android:drawablePadding="@dimen/space_sm"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingHorizontal="@dimen/space_xl"
                    android:paddingVertical="14dp"
                    android:text="@string/guide_btn_end"
                    android:textColor="@color/color_white"
                    android:textSize="@dimen/text_guide_body_lg"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/sos_modal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80090F47"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        tools:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="24dp"
            android:background="@drawable/bg_card_danger_outline"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_danger_soft"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@drawable/ic_warning_triangle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/guide_sos_alert_title"
                    android:textColor="@color/guide_danger"
                    android:textSize="@dimen/text_guide_body_lg"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:lineSpacingExtra="4dp"
                android:text="@string/guide_sos_alert_body"
                android:textColor="@color/guide_navy_70"
                android:textSize="@dimen/text_guide_body" />

            <TextView
                android:id="@+id/btn_sos_ack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_btn_danger"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:text="@string/action_known"
                android:textColor="@color/color_white"
                android:textSize="@dimen/text_guide_body"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
