<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/guide_bg_light"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="64dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/space_lg"
                android:paddingVertical="@dimen/space_md">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:contentDescription="@string/action_back"
                    android:focusable="true"
                    android:padding="6dp"
                    android:src="@drawable/ic_chevron_left" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="@string/page_guide_settings"
                    android:textColor="@color/guide_navy"
                    android:textSize="@dimen/text_guide_body_lg"
                    android:textStyle="bold" />

                <View
                    android:layout_width="36dp"
                    android:layout_height="36dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:background="@drawable/bg_settings_role_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_lg">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_settings_role_icon"
                    android:contentDescription="@null"
                    android:padding="12dp"
                    android:src="@drawable/ic_users"
                    android:tint="@color/color_white" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_md"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_current_role"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_role_guide_label"
                        android:textColor="@color/color_white"
                        android:textSize="@dimen/text_guide_body_lg"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_switch_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_role_chip"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/space_md"
                    android:paddingVertical="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_arrows_rotate"
                        android:tint="@color/color_white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/settings_switch_role"
                        android:textColor="@color/color_white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="@string/settings_section_tts"
                android:textColor="@color/guide_navy_45"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:background="@drawable/bg_card_panel"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/space_lg">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_volume_high" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_sm"
                            android:text="@string/settings_tts_speed"
                            android:textColor="@color/guide_navy"
                            android:textSize="@dimen/text_guide_body"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_md"
                        android:background="@drawable/bg_seg_container"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/seg_tts_slow"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_seg_inactive"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:paddingVertical="8dp"
                            android:text="@string/settings_tts_slow"
                            android:textColor="@color/guide_navy"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/seg_tts_normal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_seg_active"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:paddingVertical="8dp"
                            android:text="@string/settings_tts_normal"
                            android:textColor="@color/color_white"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/seg_tts_fast"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_seg_inactive"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:paddingVertical="8dp"
                            android:text="@string/settings_tts_fast"
                            android:textColor="@color/guide_navy"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="11dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_circle_info" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/settings_tts_demo"
                            android:textColor="@color/guide_navy_45"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/guide_divider" />

                <LinearLayout
                    android:id="@+id/row_vibration"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_lg">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_mobile_screen" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/settings_vibration_title"
                            android:textColor="@color/guide_navy"
                            android:textSize="@dimen/text_guide_body"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/settings_vibration_subtitle"
                            android:textColor="@color/guide_navy_45"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <FrameLayout
                        android:id="@+id/toggle_vibration"
                        android:layout_width="44dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_toggle_on"
                        android:padding="2dp">

                        <View
                            android:id="@+id/toggle_vibration_dot"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="end|center_vertical"
                            android:background="@drawable/bg_toggle_dot" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="@string/settings_section_safety"
                android:textColor="@color/guide_navy_45"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:background="@drawable/bg_card_panel"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/row_contacts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_lg">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_phone_volume" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/page_guide_contacts"
                            android:textColor="@color/guide_navy"
                            android:textSize="@dimen/text_guide_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_contacts_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/guide_navy_45"
                            android:textSize="11sp"
                            tools:text="已添加 2 人" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/guide_navy_45" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/guide_divider" />

                <LinearLayout
                    android:id="@+id/row_bluetooth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/space_lg">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_bluetooth_b" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/guide_bluetooth_manage"
                            android:textColor="@color/guide_navy"
                            android:textSize="@dimen/text_guide_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_bluetooth_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textColor="@color/guide_navy_45"
                            android:textSize="11sp"
                            tools:text="跑者的手机 · 已连接" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/guide_navy_45" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_marginTop="@dimen/space_lg"
                android:layout_marginBottom="@dimen/space_sm"
                android:text="@string/settings_section_other"
                android:textColor="@color/guide_navy_45"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/row_about"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_lg"
                android:background="@drawable/bg_card_panel"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_lg">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_circle_info"
                    android:tint="@color/guide_brand" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_sm"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/page_guide_about"
                        android:textColor="@color/guide_navy"
                        android:textSize="@dimen/text_guide_body"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_about_subtitle"
                        android:textColor="@color/guide_navy_45"
                        android:textSize="11sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/guide_navy_45" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_version_footer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2xl"
                android:gravity="center"
                android:textColor="@color/guide_navy_45"
                android:textSize="12sp"
                tools:text="RunGether v1.0.0" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/switch_role_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80090F47"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="@dimen/space_2xl"
            android:background="@drawable/bg_dialog_white"
            android:orientation="vertical"
            android:padding="@dimen/space_xl">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_circle_brand_soft"
                android:contentDescription="@null"
                android:padding="12dp"
                android:src="@drawable/ic_arrows_rotate" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:text="@string/settings_switch_dialog_title"
                android:textColor="@color/guide_navy"
                android:textSize="@dimen/text_guide_body_lg"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:text="@string/settings_switch_dialog_subtitle"
                android:textColor="@color/guide_navy_70"
                android:textSize="@dimen/text_guide_body" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_lg"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_switch_cancel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_neutral_outline"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingVertical="@dimen/space_md"
                    android:text="@string/action_cancel"
                    android:textColor="@color/guide_navy"
                    android:textSize="@dimen/text_guide_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_switch_confirm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_btn_brand_pill_md"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingVertical="@dimen/space_md"
                    android:text="@string/action_confirm"
                    android:textColor="@color/color_white"
                    android:textSize="@dimen/text_guide_body"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
