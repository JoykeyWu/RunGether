<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_panel"
    android:clickable="true"
    android:focusable="true"
    android:longClickable="true"
    android:orientation="vertical"
    android:padding="@dimen/space_lg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_calendar"
            android:tint="@color/guide_brand" />

        <TextView
            android:id="@+id/tv_item_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:textColor="@color/guide_navy"
            android:textSize="@dimen/text_guide_body"
            android:textStyle="bold"
            tools:text="2026-05-20" />

        <TextView
            android:id="@+id/tv_item_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_today_chip"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="@color/guide_brand"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="今天" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_item_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/guide_brand"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="4.15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/metric_distance_short"
                android:textColor="@color/guide_navy_45"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_item_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/guide_navy"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="32:18" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/metric_duration_short"
                android:textColor="@color/guide_navy_45"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_item_pace"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/guide_navy"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="7'47''" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/metric_pace_short"
                android:textColor="@color/guide_navy_45"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
