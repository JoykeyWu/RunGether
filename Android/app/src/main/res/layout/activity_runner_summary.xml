<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runner_bg"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/space_xl">

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_2xl"
            android:background="@drawable/bg_circle_runner_border_success">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_check"
                android:tint="@color/runner_success" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_lg"
            android:letterSpacing="0.1"
            android:text="@string/runner_summary_title"
            android:textColor="@color/runner_high"
            android:textSize="@dimen/text_runner_title"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/space_sm"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_volume_high"
                android:tint="@color/runner_accent" />

            <TextView
                android:id="@+id/tv_speech_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_sm"
                android:text="@string/runner_summary_speech"
                android:textColor="@color/runner_high_70"
                android:textSize="@dimen/text_guide_body_lg" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_xl"
            android:background="@drawable/bg_runner_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_lg">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_runner_border_white">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_calendar"
                    android:tint="@color/runner_high" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/runner_summary_field_date"
                    android:textColor="@color/runner_high_70"
                    android:textSize="@dimen/text_guide_body_lg" />

                <TextView
                    android:id="@+id/tv_summary_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/placeholder_dash"
                    android:textColor="@color/runner_high"
                    android:textSize="@dimen/text_runner_body_lg"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_runner_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_lg">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_runner_border_accent">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_clock_history"
                    android:tint="@color/runner_accent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/runner_summary_field_duration"
                    android:textColor="@color/runner_high_70"
                    android:textSize="@dimen/text_guide_body_lg" />

                <TextView
                    android:id="@+id/tv_summary_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/placeholder_duration_zero_long"
                    android:textColor="@color/runner_accent"
                    android:textSize="@dimen/text_runner_title"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_runner_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_lg">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_runner_border_accent">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_location_dot"
                    android:tint="@color/runner_accent" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/runner_summary_field_distance"
                    android:textColor="@color/runner_high_70"
                    android:textSize="@dimen/text_guide_body_lg" />

                <TextView
                    android:id="@+id/tv_summary_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/placeholder_distance_zero_km"
                    android:textColor="@color/runner_accent"
                    android:textSize="@dimen/text_runner_title"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_runner_panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/space_lg">

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_circle_runner_border_white">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_gauge"
                    android:tint="@color/runner_high" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_lg"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/runner_summary_field_pace"
                    android:textColor="@color/runner_high_70"
                    android:textSize="@dimen/text_guide_body_lg" />

                <TextView
                    android:id="@+id/tv_summary_pace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/placeholder_dash"
                    android:textColor="@color/runner_high"
                    android:textSize="@dimen/text_runner_title"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/btn_back_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/space_lg"
            android:layout_marginTop="@dimen/space_2xl"
            android:background="@drawable/bg_runner_btn_accent"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:paddingVertical="@dimen/space_xl"
            android:text="@string/runner_summary_back"
            android:textColor="@color/runner_bg"
            android:textSize="@dimen/text_runner_body_lg"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
