<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card_success_outline"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="14dp"
    android:paddingVertical="14dp">

    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circle_success_chip" />

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_mobile"
            android:tint="@color/guide_success" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_bonded_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/guide_navy"
            android:textSize="@dimen/text_guide_body"
            android:textStyle="bold"
            tools:text="跑者的手机" />

        <TextView
            android:id="@+id/tv_bonded_mac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/guide_navy_45"
            android:textSize="12sp"
            tools:text="MAC: 0C:54:15:**:**:A2" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_bonded_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_pill_success"
        android:clickable="true"
        android:focusable="true"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:textColor="@color/color_white"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:text="已连接" />
</LinearLayout>
