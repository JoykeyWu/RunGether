<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/runner_danger_pressed" />
            <stroke
                android:width="@dimen/border_runner"
                android:color="@color/runner_border" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/runner_danger" />
            <stroke
                android:width="@dimen/border_runner"
                android:color="@color/runner_border" />
        </shape>
    </item>
</selector>
